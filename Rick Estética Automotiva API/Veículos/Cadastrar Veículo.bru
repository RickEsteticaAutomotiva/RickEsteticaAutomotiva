meta {
  name: Cadastrar Veículo
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/veiculos
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "marca": "Toyota",
    "modelo": "Corolla",
    "ano": 2020,
    "placa": "ABC1234",
    "pessoaId": 1
  }
}

settings {
  encodeUrl: true
}

# =====================================================
# .env.example — Template de Variáveis de Ambiente
# PROPÓSITO: Documentar todas as variáveis necessárias
# =====================================================
#
# INSTRUÇÕES:
# 1. DEV LOCAL: Copie para .env.local, remova "example" e preencha valores
# 2. DOCKER: Use este arquivo como referência, injete via docker-compose.yml
# 3. EC2 PRODUÇÃO: Use AWS Secrets Manager (veja SECRETS_DEPLOYMENT.md)
#
# SEGURANÇA:
# - .env.local é gitignored — NUNCA commit
# - Valores aqui são EXAMPLES — substitua pelos reais
# =====================================================

# =====================================================
# DATABASE — MySQL
# =====================================================
DB_URL=jdbc:mysql://localhost:3306/rick_dev?useUnicode=true&characterEncoding=UTF-8&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=rick
DB_PASSWORD=rick@dev2024

# =====================================================
# JWT — Autenticação
# =====================================================
# Gere um novo secret com:
#   java -jar jjwt-cli.jar createKey.jws
# Valor exemplo (base64): Existe uma teoria que diz que, se um dia alguém descobrir exatamente para que serve o
JWT_SECRET=RXhpc3RlIHVtYSB0ZW9yaWEgcXVlIGRpeiBxdWUsIHNlIHVtIGRpYSBhbGd16W0gZGVzY29icmlyIGV4YXRhbWVudGUgcGFyYSBxdWUgc2VydmUgby

# =====================================================
# EMAIL — SMTP
# =====================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app

# =====================================================
# RABBITMQ — Mensageria
# =====================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=123456

# =====================================================
# CORS — Controle de Origem
# =====================================================
# DEV: aceita todas (*), HOMOLOG/PROD: específico
ALLOWED_CORS_ORIGINS=*

# =====================================================
# SPRING PROFILES — Ambiente
# =====================================================
# Valores válidos: dev, homolog, prod (ative um)
SPRING_PROFILES_ACTIVE=dev,swagger

# =====================================================
# CONFIGURAÇÕES ADICIONAIS (Opcional)
# =====================================================
# Observação: A aplicação pode usar valores defaults se não definidos
# Mas para PROD, TODOS os secrets são OBRIGATÓRIOS

